# Copy to .env.local (app) and set the same values in the Railway service's
# variables (workers). Every var below is actually read by app or worker
# code — this file intentionally does not mirror every var that might exist
# in someone's .env.local, only what's load-bearing.

# ── Supabase (required) ──────────────────────────────────────────────────
# Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Workers only — service role bypasses RLS, never expose to the browser or
# commit a real value. Also required by a few admin-only Vercel routes
# (lib/supabase/admin.ts), gated behind requireAdmin().
SUPABASE_SERVICE_ROLE_KEY=
# Workers connect directly (not through the Next.js app), so they need the
# bare URL too — same value as NEXT_PUBLIC_SUPABASE_URL, without the prefix.
SUPABASE_URL=

# ── AI providers (required for the features that use them) ──────────────
# QBIQ/OLIQ/TEAMIQ/MISTAKEIQ frame analysis, PlaybookIQ page classification
# + assignment extraction. Either name works — GOOGLE_API_KEY is checked
# first, GEMINI_API_KEY is the fallback.
GOOGLE_API_KEY=
GEMINI_API_KEY=
# PlaybookIQ whole-book analysis, PlayScoutIQ chat.
ANTHROPIC_API_KEY=
# Reserved for the football_knowledge job type (not yet wired to a route).
PERPLEXITY_API_KEY=
# Reserved for team_memory embeddings (lib/ai/providers/openai.ts).
OPENAI_API_KEY=

# ── AI cost controls (optional) ──────────────────────────────────────────
# Set to "true" to stop every AI route and the playbook worker from making
# provider calls (checked in lib/ai/guard.ts and workers/process-playbook.ts).
AI_GLOBAL_DISABLE=

# ── Workers (optional — sane defaults if unset) ──────────────────────────
WORKER_ID=playscout-worker-001
# Video worker: ms between polls for a queued job. Default 5000.
POLL_INTERVAL_MS=
# Video worker: frames extracted per full-game video. Default 16.
FRAME_COUNT=
# Playbook worker: concurrent Gemini calls per playbook. Default 4.
PLAYBOOK_VISION_CONCURRENCY=

# ── Error monitoring (optional — safely no-ops until a Sentry account
#    exists; every capture call is a silent no-op with these unset) ───────
NEXT_PUBLIC_SENTRY_DSN=
# Server + edge runtime + both workers.
SENTRY_DSN=
# Only needed to upload source maps at build time (requires a Sentry auth
# token) — the build succeeds fine without these.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Integration tests (optional — see that file's header for full context)
# lib/auth/require-team-member.integration.test.ts creates and deletes real
# auth users to exercise RLS with genuine sessions; skipped unless this is
# explicitly set to "true".
RUN_INTEGRATION_TESTS=
